# ============================================================
# TSUNAMI ERP — Variables de entorno
# Copiar este archivo a .env.local y completar con los valores
# reales del proyecto de Supabase (Dashboard → Settings → API).
# ============================================================

# URL del proyecto Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Clave pública (anon) de Supabase
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# Clave de servicio (solo para operaciones administrativas del servidor;
# NUNCA exponer al cliente)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# Clave de la API de Anthropic para el Asistente IA (Módulo 10)
ANTHROPIC_API_KEY=sk-ant-...
